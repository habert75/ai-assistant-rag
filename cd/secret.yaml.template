apiVersion: v1
kind: Secret
metadata:
  name: openai-api-key
  namespace: ai-assistant-rag
type: Opaque
stringData:
  # Replace with your actual OpenAI API key
  # Copy this file to cd/secret.yaml and add your key
  # IMPORTANT: cd/secret.yaml is in .gitignore and will NOT be committed
  OPENAI_API_KEY: "your_openai_api_key_here"
